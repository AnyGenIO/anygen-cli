{
  "name": "@anygen/cli",
  "version": "0.1.0",
  "description": "AnyGen CLI - AI-powered content generation platform",
  "type": "module",
  "bin": {
    "anygen": "bin/anygen.js"
  },
  "files": [
    "bin/",
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "!dist/__tests__/",
    "skills/",
    "README.md",
    "README.zh-CN.md"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "prepublishOnly": "rm -rf dist && npm run build && npm test",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "cli",
    "anygen",
    "ppt",
    "doc",
    "image",
    "diagram",
    "ai-agent",
    "agent-skills"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AnyGenIO/anygen-cli.git"
  },
  "homepage": "https://www.anygen.io/",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "playwright-core": "^1.50.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  }
}
